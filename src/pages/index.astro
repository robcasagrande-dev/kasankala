---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kásankala | Il sapore ancestrale del Tayrona">
	<main>
		<!-- Hero Section -->
		<section class="hero animate-fade-in">
            <div class="hero-overlay"></div>
            <div class="hero-content container">
                <p class="hero-subtitle">Prossima Apertura</p>
                <h1 class="hero-title">Kásankala.</h1>
                <p class="hero-tagline">Dove la selva incontra l'anima.</p>
            </div>
		</section>

		<!-- Concept Section -->
		<section id="concept" class="concept-section container">
            <div class="concept-grid">
                <div class="concept-text">
                    <h2 class="section-title">L'Essenza</h2>
                    <p class="section-desc">
                        Un rifugio nel cuore del Tayrona. Un'esperienza culinaria scolpita dalle radici ancestrali.
                        Lasciati avvolgere dall'energia della montagna e dalla purezza del mare.
                    </p>
                </div>
                <div class="concept-image-wrapper">
                    <img src="/images/concept.jpg" alt="Atmosfera Kásankala" class="concept-image" />
                </div>
            </div>
		</section>

	</main>
</Layout>

<style>
	/* Hero */
	.hero {
		position: relative;
		height: 100vh;
		min-height: 600px;
		display: flex;
		align-items: center;
		justify-content: center;
		background-image: url('/images/hero.jpg');
		background-size: cover;
		background-position: center;
        background-attachment: fixed;
	}
	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(180deg, rgba(5,5,5,0.7) 0%, rgba(5,5,5,0.4) 50%, rgba(5,5,5,1) 100%);
		z-index: 1;
	}
	.hero-content {
		position: relative;
		z-index: 2;
		text-align: center;
        margin-top: var(--spacing-xl);
	}
	.hero-subtitle {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: var(--color-gold);
		margin-bottom: var(--spacing-sm);
	}
	.hero-title {
		font-size: 5rem;
		margin-bottom: var(--spacing-sm);
        text-shadow: 0 4px 20px rgba(0,0,0,0.5);
	}
	.hero-tagline {
		font-size: 1.2rem;
		font-weight: 300;
		letter-spacing: 0.05em;
		opacity: 0.9;
	}

    /* Concept Section */
    .concept-section {
        padding: var(--spacing-xxl) var(--spacing-md);
    }
    .concept-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--spacing-lg);
        align-items: center;
    }
    @media (min-width: 768px) {
        .concept-grid {
            grid-template-columns: 1fr 1fr;
            gap: var(--spacing-xl);
        }
    }
    .section-title {
        font-size: 3rem;
        margin-bottom: var(--spacing-md);
    }
    .section-desc {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--color-gray);
        max-width: 400px;
    }
    .concept-image-wrapper {
        position: relative;
        padding-top: 120%; /* Aspect ratio for portrait */
        overflow: hidden;
    }
    .concept-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(20%) contrast(110%);
        transition: transform 1s ease;
    }
    .concept-image-wrapper:hover .concept-image {
        transform: scale(1.03);
    }

    @media (max-width: 768px) {
        .hero-title {
            font-size: 3rem;
        }
    }
</style>
