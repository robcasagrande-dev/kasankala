---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kásankala | El sabor ancestral del Tayrona">
	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="hero-overlay"></div>
			<div class="container hero-content">
				<p class="subtitle animate-fade-in">Próxima Apertura</p>
				<h1 class="title animate-slide-up">KÁsankala</h1>
				<p class="tagline animate-fade-in-delayed">Donde la selva encuentra el alma.</p>
			</div>
		</section>

		<!-- Concept Section (Placeholder for future content) -->
		<section id="concept" class="concept-section">
			<div class="container concept-container">
				<h2 class="section-title">La Esencia</h2>
				<p class="concept-text">
					<span class="highlight">Kásankala</span> nace de la unión de dos voces ancestrales de la Sierra: <em>Kas</em>, que representa la tierra sagrada y la energía vital que brota de la montaña, y <em>Ankala</em>, el refugio y la conexión profunda entre la naturaleza y el espíritu.
					<br><br>
					Más que un restaurante, es un santuario en el corazón del Tayrona donde cada sabor es un tributo a nuestras raíces. Una experiencia culinaria esculpida por la sabiduría antigua, donde la energía de la selva abraza la pureza del mar.
				</p>
			</div>
		</section>

		<!-- Atmosfera / Gallery Section -->
		<section id="gallery" class="gallery-section">
			<div class="container">
				<h2 class="section-title text-center">Atmósfera</h2>
				<div class="gallery-grid">
					<div class="gallery-item tall">
						<img src="/images/jeyson becerra-04789.JPG" alt="Atmósfera Kásankala 1" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item wide">
						<img src="/images/WhatsApp Image 2023-12-31 at 10.38.14-EDIT.jpg" alt="Atmósfera Kásankala 2" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item">
						<img src="/images/jeyson becerra-04914~4.JPG" alt="Atmósfera Kásankala 3" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item">
						<img src="/images/jeyson becerra-01351~2.JPG" alt="Atmósfera Kásankala 4" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item wide">
						<img src="/images/jeyson becerra-04829.JPG" alt="Atmósfera Kásankala 5" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item tall">
						<img src="/images/WhatsApp Image 2023-12-31 at 10.37.09-EDIT.jpg" alt="Atmósfera Kásankala 6" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item">
						<img src="/images/PXL_20250509_000455186~4.jpg" alt="Atmósfera Kásankala 7" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item wide">
						<img src="/images/PXL_20250517_235602952~3.jpg" alt="Atmósfera Kásankala 8" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item tall">
						<img src="/images/WhatsApp Image 2023-12-31 at 10.37.48-EDIT.jpg" alt="Atmósfera Kásankala 9" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item">
						<img src="/images/WhatsApp Image 2023-12-31 at 10.39.16-EDIT.jpg" alt="Atmósfera Kásankala 10" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item wide">
						<img src="/images/jeyson becerra-04679~2.JPG" alt="Atmósfera Kásankala 11" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item tall">
						<img src="/images/jeyson becerra-04957~2.JPG" alt="Atmósfera Kásankala 12" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* Hero Section */
	.hero {
		position: relative;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		overflow: hidden;
		/* Base background image set in global.css to avoid repetition, 
		   but can be overridden here if needed */
		background-image: url('/images/hero-bg.jpg'); /* The real image */
		background-size: cover;
		background-position: center;
	}

	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(5, 5, 5, 0.6); /* Dark overlay for text readability */
		z-index: 1;
	}

	.hero-content {
		position: relative;
		z-index: 2;
	}

	.title {
		font-size: clamp(4rem, 10vw, 8rem);
		color: var(--color-gold);
		margin-bottom: var(--spacing-sm);
		text-shadow: 0 4px 20px rgba(0,0,0,0.5);
	}

	.subtitle {
		font-family: var(--font-body);
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: var(--color-white);
		margin-bottom: var(--spacing-md);
	}

	.tagline {
		font-size: 1.5rem;
		color: var(--color-gray);
		font-style: italic;
	}

	/* Concept Section */
	.concept-section {
		padding: var(--spacing-xxl) 0;
		background-color: var(--color-bg);
		text-align: center;
	}

	.concept-container {
		max-width: 800px;
	}

	.section-title {
		font-size: 2.5rem;
		color: var(--color-gold);
		margin-bottom: var(--spacing-lg);
	}

	.concept-text {
		font-size: 1.2rem;
		line-height: 1.8;
		color: var(--color-gray);
	}

	.concept-text .highlight {
		color: var(--color-gold);
		font-weight: 600;
		font-size: 1.3rem;
	}

	/* Animations */
	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	@keyframes slideUp {
		from { 
			opacity: 0; 
			transform: translateY(40px);
		}
		to { 
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fadeIn 1.5s ease-out forwards;
	}

	.animate-slide-up {
		animation: slideUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
		opacity: 0; /* Starts hidden */
		animation-delay: 0.3s;
	}

	.animate-fade-in-delayed {
		animation: fadeIn 1.5s ease-out forwards;
		opacity: 0;
		animation-delay: 1s;
	}

	/* Gallery Section */
	.gallery-section {
		padding: var(--spacing-xxl) 0;
		background-color: #050505; /* Slightly darker than base bg for contrast */
	}

	.text-center {
		text-align: center;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		grid-auto-rows: 250px;
		grid-auto-flow: dense;
		gap: 15px;
		padding: 0 var(--spacing-md);
	}

	.gallery-item {
		position: relative;
		overflow: hidden;
		border-radius: 4px;
		cursor: pointer;
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	.gallery-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(212, 175, 55, 0);
		transition: background 0.3s ease;
		pointer-events: none;
	}

	.gallery-item:hover .gallery-overlay {
		background: rgba(212, 175, 55, 0.15); /* Subtle gold tint on hover */
	}

	/* Masonry effect classes */
	@media (min-width: 768px) {
		.gallery-item.wide {
			grid-column: span 2;
		}
		.gallery-item.tall {
			grid-row: span 2;
		}
	}
</style>
