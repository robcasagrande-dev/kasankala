---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kásankala | El sabor ancestral del Tayrona">
	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="hero-overlay"></div>
			<div class="container hero-content">
				<p class="subtitle animate-fade-in">Próxima Apertura</p>
				<h1 class="title animate-slide-up">KÁsankala</h1>
				<p class="tagline animate-fade-in-delayed">Donde la selva encuentra el alma.</p>
			</div>
		</section>

		<!-- Concept Section (Placeholder for future content) -->
		<section id="concept" class="concept-section">
			<div class="container concept-container">
				<h2 class="section-title">La Esencia</h2>
				<p class="concept-text">
					Un refugio en el corazón del Tayrona. Una experiencia culinaria esculpida por raíces ancestrales. Déjate envolver por la energía de la montaña y la pureza del mar.
				</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* Hero Section */
	.hero {
		position: relative;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		overflow: hidden;
		/* Base background image set in global.css to avoid repetition, 
		   but can be overridden here if needed */
		background-image: url('/bg.png'); /* The beautiful image we copied earlier */
		background-size: cover;
		background-position: center;
	}

	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(5, 5, 5, 0.6); /* Dark overlay for text readability */
		z-index: 1;
	}

	.hero-content {
		position: relative;
		z-index: 2;
	}

	.title {
		font-size: clamp(4rem, 10vw, 8rem);
		color: var(--color-gold);
		margin-bottom: var(--spacing-sm);
		text-shadow: 0 4px 20px rgba(0,0,0,0.5);
	}

	.subtitle {
		font-family: var(--font-body);
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: var(--color-white);
		margin-bottom: var(--spacing-md);
	}

	.tagline {
		font-size: 1.5rem;
		color: var(--color-gray);
		font-style: italic;
	}

	/* Concept Section */
	.concept-section {
		padding: var(--spacing-xxl) 0;
		background-color: var(--color-bg);
		text-align: center;
	}

	.concept-container {
		max-width: 800px;
	}

	.section-title {
		font-size: 2.5rem;
		color: var(--color-gold);
		margin-bottom: var(--spacing-lg);
	}

	.concept-text {
		font-size: 1.2rem;
		line-height: 1.8;
		color: var(--color-gray);
	}

	/* Animations */
	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	@keyframes slideUp {
		from { 
			opacity: 0; 
			transform: translateY(40px);
		}
		to { 
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fadeIn 1.5s ease-out forwards;
	}

	.animate-slide-up {
		animation: slideUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
		opacity: 0; /* Starts hidden */
		animation-delay: 0.3s;
	}

	.animate-fade-in-delayed {
		animation: fadeIn 1.5s ease-out forwards;
		opacity: 0;
		animation-delay: 1s;
	}
</style>
