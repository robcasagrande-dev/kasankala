---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Menu | Kásankala">
	<main class="menu-page">
		<section class="menu-header animate-fade-in">
            <div class="container">
                <h1 class="page-title">Il Menu</h1>
                <p class="page-subtitle">Un viaggio culinario tra i sapori ancestrali e le tecniche moderne.</p>
            </div>
		</section>

		<section class="menu-content container animate-slide-up">
            <!-- Placeholder Category 1 -->
            <div class="menu-category">
                <h2 class="category-title">Antipasti</h2>
                
                <div class="menu-item">
                    <div class="item-header">
                        <h3 class="item-name">Ceviche Tayrona</h3>
                        <span class="item-price">$XX</span>
                    </div>
                    <p class="item-desc">Pesce fresco locale, leche de tigre al frutto della passione, platano croccante.</p>
                </div>
                
                <div class="menu-item">
                    <div class="item-header">
                        <h3 class="item-name">Carpaccio di Terra</h3>
                        <span class="item-price">$XX</span>
                    </div>
                    <p class="item-desc">Filetto stagionato, scaglie di formaggio artigianale, emulsione di erbe selvatiche.</p>
                </div>
            </div>

            <!-- Placeholder Category 2 -->
            <div class="menu-category">
                <h2 class="category-title">Piatti Principali</h2>
                
                <div class="menu-item">
                    <div class="item-header">
                        <h3 class="item-name">Polpo Braciato</h3>
                        <span class="item-price">$XX</span>
                    </div>
                    <p class="item-desc">Polpo cotto a bassa temperatura, crema di patate andine, chimichurri affumicato.</p>
                </div>
                
                <div class="menu-item">
                    <div class="item-header">
                        <h3 class="item-name">Risotto della Selva</h3>
                        <span class="item-price">$XX</span>
                    </div>
                    <p class="item-desc">Riso mantecato ai funghi di foresta, tartufo nero, riduzione di vino rosso.</p>
                </div>
            </div>

            <!-- Placeholder Category 3 -->
            <div class="menu-category">
                <h2 class="category-title">Dessert</h2>
                
                <div class="menu-item">
                    <div class="item-header">
                        <h3 class="item-name">Cacao Assoluto</h3>
                        <span class="item-price">$XX</span>
                    </div>
                    <p class="item-desc">Tre consistenze di cioccolato fondente della Sierra Nevada, sale marino.</p>
                </div>
            </div>
		</section>
	</main>
</Layout>

<style>
	.menu-page {
        padding-top: 120px; /* Spazio per l'header fisso */
        min-height: 100vh;
	}
    
    .menu-header {
        text-align: center;
        padding: var(--spacing-xl) 0 var(--spacing-lg);
        border-bottom: 1px solid rgba(212, 175, 55, 0.1);
    }
    
    .page-title {
        font-size: 4rem;
        margin-bottom: var(--spacing-sm);
    }
    
    .page-subtitle {
        font-size: 1.1rem;
        color: var(--color-gray);
        max-width: 600px;
        margin: 0 auto;
        font-weight: 300;
        letter-spacing: 0.05em;
    }

    .menu-content {
        max-width: 800px;
        padding: var(--spacing-xl) var(--spacing-md);
    }

    .menu-category {
        margin-bottom: var(--spacing-xl);
    }

    .category-title {
        font-size: 2rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: var(--spacing-md);
        text-align: center;
        color: var(--color-white); /* Contrasto per staccare dal titolo principale oro */
    }

    .menu-item {
        margin-bottom: var(--spacing-md);
    }

    .item-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.25rem;
    }

    .item-name {
        font-family: var(--font-body);
        font-size: 1.2rem;
        color: var(--color-gold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .item-price {
        font-family: var(--font-display);
        font-size: 1.2rem;
        color: var(--color-white);
    }

    .item-desc {
        color: var(--color-gray);
        font-size: 0.95rem;
        font-weight: 300;
        max-width: 85%;
    }

    /* Animation classes */
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-slide-up {
        animation: slideUp 1s ease-out forwards;
        animation-delay: 0.3s;
        opacity: 0;
    }
</style>
