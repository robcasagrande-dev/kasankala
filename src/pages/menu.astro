---
import Layout from '../layouts/Layout.astro';
import menuData from '../data/menu_optimizado.json';

// Formattatore di valuta colombiano (COP)
const formatPrice = (price) => {
    return new Intl.NumberFormat('es-CO', {
        style: 'currency',
        currency: 'COP',
        minimumFractionDigits: 0
    }).format(price);
};
---

<Layout 
	title="Menú de Kásankala | Restaurante en Parque Tayrona" 
	description="Explora el menú de Kásankala, un viaje culinario entre sabores ancestrales y técnicas modernas en el corazón del Parque Tayrona."
>
	<main class="menu-page">
		<section class="menu-header animate-fade-in">
            <div class="container">
                <h1 class="page-title">El Menú</h1>
                <p class="page-subtitle">Un viaje culinario entre sabores ancestrales y técnicas modernas.</p>
            </div>
		</section>

		<section class="menu-content container animate-slide-up">
            {menuData.map((categoryData, index) => (
                <div class="menu-category" style={`animation-delay: ${0.2 * index}s;`}>
                    <h2 class="category-title">{categoryData.categoria}</h2>
                    
                    {categoryData.items.map((item) => (
                        <div class="menu-item">
                            <div class="item-header">
                                <h3 class="item-name">{item.nombre}</h3>
                                <span class="item-price">{formatPrice(item.precio)}</span>
                            </div>
                            <p class="item-desc">{item.descripcion}</p>
                        </div>
                    ))}
                </div>
            ))}
		</section>
	</main>
</Layout>

<style>
	.menu-page {
        padding-top: 120px;
        min-height: 100vh;
	}
    
    .menu-header {
        text-align: center;
        padding: var(--spacing-xl) 0 var(--spacing-lg);
        border-bottom: 1px solid rgba(212, 175, 55, 0.1);
    }
    
    .page-title {
        font-size: 4rem;
        margin-bottom: var(--spacing-sm);
    }
    
    .page-subtitle {
        font-size: 1.1rem;
        color: var(--color-gray);
        max-width: 600px;
        margin: 0 auto;
        font-weight: 300;
        letter-spacing: 0.05em;
    }

    .menu-content {
        max-width: 800px;
        padding: var(--spacing-xl) var(--spacing-md);
    }

    .menu-category {
        margin-bottom: var(--spacing-xl);
        animation: fadeIn 1s ease-out forwards;
        opacity: 0;
    }

    .category-title {
        font-size: 2rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: var(--spacing-md);
        text-align: center;
        color: var(--color-white);
        border-bottom: 1px dashed rgba(212, 175, 55, 0.3);
        padding-bottom: 0.5rem;
        display: inline-block;
        width: 100%;
    }

    .menu-item {
        margin-bottom: var(--spacing-md);
        transition: transform 0.3s;
    }
    
    .menu-item:hover {
        transform: translateX(10px);
    }

    .item-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.25rem;
        border-bottom: 1px dotted rgba(255, 255, 255, 0.1);
    }

    .item-name {
        font-family: var(--font-body);
        font-size: 1.2rem;
        color: var(--color-gold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding-right: 1rem;
    }

    .item-price {
        font-family: var(--font-display);
        font-size: 1.2rem;
        color: var(--color-white);
        white-space: nowrap;
    }

    .item-desc {
        color: var(--color-gray);
        font-size: 0.95rem;
        font-weight: 300;
        max-width: 85%;
        margin-top: 0.25rem;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .animate-slide-up {
        animation: slideUp 1s ease-out forwards;
        animation-delay: 0.3s;
        opacity: 0;
    }

    @media (max-width: 768px) {
        .menu-page {
            padding-top: 90px;
        }
        .menu-header {
            padding: var(--spacing-lg) 0 var(--spacing-md);
        }
        .page-title {
            font-size: 2.5rem;
        }
        .page-subtitle {
            font-size: 0.95rem;
            padding: 0 var(--spacing-sm);
        }
        .menu-content {
            padding: var(--spacing-lg) var(--spacing-sm);
        }
        .menu-category {
            margin-bottom: var(--spacing-lg);
        }
        .category-title {
            font-size: 1.5rem;
            margin-bottom: var(--spacing-md);
        }
        .menu-item {
            transform: none !important; /* disable horizontal slide on mobile */
            padding: 0.25rem 0;
        }
        .item-header {
            flex-wrap: wrap;
            gap: 0.25rem;
        }
        .item-name {
            font-size: 1rem;
            padding-right: 0.5rem;
        }
        .item-price {
            font-size: 1rem;
        }
        .item-desc {
            max-width: 100%;
            font-size: 0.9rem;
        }
    }
</style>
