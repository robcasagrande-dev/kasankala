---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Menú de Kásankala | Restaurante en Parque Tayrona" 
	description="Explora el menú de Kásankala, un viaje culinario entre sabores ancestrales y técnicas modernas en el corazón del Parque Tayrona."
>
	<main class="menu-page">
		<iframe 
            src="https://api.kalihotels.com/menu/" 
            class="menu-iframe"
            title="Menú Kásankala"
            frameborder="0"
        ></iframe>
	</main>
</Layout>

<style>
	.menu-page {
        /* We remove the padding-top so the iframe takes full screen or adjust to nav */
        padding-top: 80px;
        min-height: 100vh;
        width: 100%;
        display: flex;
        flex-direction: column;
	}
    
    .menu-iframe {
        flex: 1;
        width: 100%;
        min-height: calc(100vh - 80px);
        border: none;
        background-color: transparent;
    }

    @media (max-width: 768px) {
        .menu-page {
            padding-top: 60px;
        }
        .menu-iframe {
            min-height: calc(100vh - 60px);
        }
    }
</style>
