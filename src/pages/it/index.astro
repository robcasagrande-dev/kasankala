---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
	title="Kásankala | Ristorante nel Parque Tayrona" 
	description="Scopri Kásankala, un ristorante esclusivo nella giungla del Parque Tayrona, Vereda Orinoco. Dove la giungla incontra l'anima."
>
	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="hero-overlay"></div>
			<div class="container hero-content">
				<h1 class="title animate-slide-up">KÁsankala</h1>
				<p class="tagline animate-fade-in-delayed">Dove la giungla incontra l'anima.</p>
			</div>
		</section>

		<!-- Concept Section -->
		<section id="concept" class="concept-section">
			<div class="container concept-container">
				<h2 class="section-title">L'Essenza</h2>
				<p class="concept-text">
					<span class="highlight">Kásankala</span> nasce dall'antica lingua Kogi: <em>Ká</em>, che significa giungla, e <em>Sankala</em>, la spiaggia dove si infrange il mare. Una parola che cattura l'essenza pura della nostra casa: la spiaggia della giungla.
					<br><br>
					Più che un ristorante, è un santuario nella Vereda Orinoco, il punto esatto dove la vegetazione della foresta abbraccia la sabbia costiera. Un'esperienza culinaria plasmata dall'antica saggezza, dove ogni sapore è un tributo alla profonda connessione tra la montagna e il mare.
				</p>
			</div>
		</section>

		<!-- Gallery Section -->
		<section id="gallery" class="gallery-section">
			<div class="container">
				<h2 class="section-title text-center">Atmosfera</h2>
				<div class="gallery-grid">
					<div class="gallery-item tall">
						<img src="/images/jeyson becerra-04789.JPG" alt="Kásankala Atmosfera 1" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item wide">
						<img src="/images/WhatsApp Image 2023-12-31 at 10.38.14-EDIT.jpg" alt="Kásankala Atmosfera 2" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item">
						<img src="/images/jeyson becerra-04914~4.JPG" alt="Kásankala Atmosfera 3" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item">
						<img src="/images/jeyson becerra-01351~2.JPG" alt="Kásankala Atmosfera 4" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item wide">
						<img src="/images/jeyson becerra-04829.JPG" alt="Kásankala Atmosfera 5" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item tall">
						<img src="/images/WhatsApp Image 2023-12-31 at 10.37.09-EDIT.jpg" alt="Kásankala Atmosfera 6" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item">
						<img src="/images/PXL_20250509_000455186~4.jpg" alt="Kásankala Atmosfera 7" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item wide">
						<img src="/images/PXL_20250517_235602952~3.jpg" alt="Kásankala Atmosfera 8" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item tall">
						<img src="/images/WhatsApp Image 2023-12-31 at 10.37.48-EDIT.jpg" alt="Kásankala Atmosfera 9" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item">
						<img src="/images/WhatsApp Image 2023-12-31 at 10.39.16-EDIT.jpg" alt="Kásankala Atmosfera 10" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item wide">
						<img src="/images/jeyson becerra-04679~2.JPG" alt="Kásankala Atmosfera 11" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
					<div class="gallery-item tall">
						<img src="/images/jeyson becerra-04957~2.JPG" alt="Kásankala Atmosfera 12" loading="lazy">
						<div class="gallery-overlay"></div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero {
		position: relative;
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		overflow: hidden;
		background-image: url('/images/hero-bg.jpg');
		background-size: cover;
		background-position: center;
	}
	.hero-overlay {
		position: absolute;
		top: 0; left: 0;
		width: 100%; height: 100%;
		background: rgba(5, 5, 5, 0.6);
		z-index: 1;
	}
	.hero-content { position: relative; z-index: 2; }
	.title {
		font-size: clamp(2.5rem, 8vw, 8rem);
		color: var(--color-gold);
		margin-bottom: var(--spacing-sm);
		text-shadow: 0 4px 20px rgba(0,0,0,0.5);
	}
	.tagline {
		font-size: clamp(1rem, 4vw, 1.5rem);
		color: var(--color-gray);
		font-style: italic;
		padding: 0 var(--spacing-sm);
	}
	.concept-section {
		padding: var(--spacing-xxl) 0;
		background-color: var(--color-bg);
		text-align: center;
	}
	.concept-container { max-width: 800px; }
	.section-title {
		font-size: 2.5rem;
		color: var(--color-gold);
		margin-bottom: var(--spacing-lg);
	}
	.concept-text {
		font-size: 1.2rem;
		line-height: 1.8;
		color: var(--color-gray);
	}
	.concept-text .highlight {
		color: var(--color-gold);
		font-weight: 600;
		font-size: 1.3rem;
	}
	@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
	@keyframes slideUp {
		from { opacity: 0; transform: translateY(40px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in { animation: fadeIn 1.5s ease-out forwards; }
	.animate-slide-up {
		animation: slideUp 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
		opacity: 0;
		animation-delay: 0.3s;
	}
	.animate-fade-in-delayed {
		animation: fadeIn 1.5s ease-out forwards;
		opacity: 0;
		animation-delay: 1s;
	}
	.gallery-section {
		padding: var(--spacing-xxl) 0;
		background-color: #050505;
	}
	.text-center { text-align: center; }
	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		grid-auto-rows: 250px;
		grid-auto-flow: dense;
		gap: 15px;
	}
	.gallery-item {
		position: relative;
		overflow: hidden;
		border-radius: 4px;
		cursor: pointer;
	}
	.gallery-item img {
		width: 100%; height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}
	.gallery-item:hover img { transform: scale(1.05); }
	.gallery-overlay {
		position: absolute;
		top: 0; left: 0;
		width: 100%; height: 100%;
		background: rgba(212, 175, 55, 0);
		transition: background 0.3s ease;
		pointer-events: none;
	}
	.gallery-item:hover .gallery-overlay { background: rgba(212, 175, 55, 0.15); }
	@media (min-width: 768px) {
		.gallery-item.wide { grid-column: span 2; }
		.gallery-item.tall { grid-row: span 2; }
	}
	@media (max-width: 768px) {
		.concept-section, .gallery-section { padding: var(--spacing-lg) 0; }
		.concept-text { font-size: 1.05rem; }
		.section-title { font-size: 2rem; margin-bottom: var(--spacing-md); }
		.gallery-grid { grid-template-columns: 1fr 1fr; grid-auto-rows: 180px; gap: 8px; }
	}
	@media (max-width: 480px) {
		.gallery-grid { grid-template-columns: 1fr; grid-auto-rows: 220px; gap: 8px; }
		.section-title { font-size: 1.75rem; }
	}
</style>
