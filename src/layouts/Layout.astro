---
import '../styles/global.css';

export interface Props {
	title: string;
    description?: string;
    keywords?: string;
}

const { 
    title, 
    description = "Kásankala: El encuentro entre la selva y el lujo en el corazón del Parque Tayrona.", 
    keywords = "restaurante, Parque Tayrona, Vereda Orinoco, gastronomía, Caribe, selva, Kásankala, Santa Marta" 
} = Astro.props;
const lang = Astro.currentLocale || 'es';
const isEn = lang === 'en';
const isDe = lang === 'de';
const isFr = lang === 'fr';
const isEs = lang === 'es';

// Compute nav prefix for each locale
const navPrefix = isEn ? '/en' : isDe ? '/de' : isFr ? '/fr' : '';
---

<!DOCTYPE html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        
        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://kasankala.com/" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content="https://kasankala.com/images/hero-bg.jpg" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content="https://kasankala.com/" />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content="https://kasankala.com/images/hero-bg.jpg" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
        <header class="site-header">
            <div class="container header-container">
                <a href="/" class="logo-link">
                    <img src="/logo-color.svg" alt="Kásankala" class="site-logo" />
                </a>
                <nav class="main-nav">
                    <!-- Minimal navigation, can be expanded later -->
                    <a href={`${navPrefix}/#concept`} class="nav-link">{isEn ? 'Essence' : isDe ? 'Essenz' : isFr ? 'Essence' : 'Esencia'}</a>
                    <a href={`${navPrefix}/#gallery`} class="nav-link">{isEn ? 'Atmosphere' : isDe ? 'Atmosphäre' : isFr ? 'Atmosphère' : 'Atmósfera'}</a>
                    <a href={`${navPrefix}/menu`} class="nav-link">{isEn ? 'Menu' : isDe ? 'Menü' : isFr ? 'Menu' : 'Menú'}</a>
                </nav>
                <div class="lang-switcher">
                    <a href="/" class={isEs ? 'active' : ''}>ES</a>
                    <span>|</span>
                    <a href="/en/" class={isEn ? 'active' : ''}>EN</a>
                    <span>|</span>
                    <a href="/de/" class={isDe ? 'active' : ''}>DE</a>
                    <span>|</span>
                    <a href="/fr/" class={isFr ? 'active' : ''}>FR</a>
                </div>
                <button id="menu-toggle" class="menu-toggle" aria-label="Toggle Menu" aria-expanded="false">
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                </button>
            </div>
        </header>

        <!-- Mobile Menu Overlay -->
        <div id="mobile-menu" class="mobile-menu-overlay">
            <nav class="mobile-nav">
                <a href={`${navPrefix}/#concept`} class="mobile-nav-link">{isEn ? 'Essence' : isDe ? 'Essenz' : isFr ? 'Essence' : 'Esencia'}</a>
                <a href={`${navPrefix}/#gallery`} class="mobile-nav-link">{isEn ? 'Atmosphere' : isDe ? 'Atmosphäre' : isFr ? 'Atmosphère' : 'Atmósfera'}</a>
                <a href={`${navPrefix}/menu`} class="mobile-nav-link">{isEn ? 'Menu' : isDe ? 'Menü' : isFr ? 'Menu' : 'Menú'}</a>
                
                <div class="mobile-lang-switcher">
                    <a href="/" class={isEs ? 'active' : ''}>ES</a>
                    <span>|</span>
                    <a href="/en/" class={isEn ? 'active' : ''}>EN</a>
                    <span>|</span>
                    <a href="/de/" class={isDe ? 'active' : ''}>DE</a>
                    <span>|</span>
                    <a href="/fr/" class={isFr ? 'active' : ''}>FR</a>
                </div>
            </nav>
        </div>

		<slot />

        <footer class="site-footer">
            <div class="container footer-container">
                <p class="footer-text">&copy; {new Date().getFullYear()} Kásankala. {isEn ? 'All rights reserved.' : 'Todos los derechos reservados.'}</p>
            </div>
        </footer>
	</body>
</html>

<style>
    .site-header {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        padding: var(--spacing-md) 0;
        z-index: 100;
        background: linear-gradient(to bottom, rgba(5,5,5,0.8) 0%, rgba(5,5,5,0) 100%);
    }
    .header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    .site-logo {
        height: 120px;
        width: auto;
        transition: height 0.3s ease;
    }
    .main-nav {
        display: flex;
        gap: var(--spacing-md);
    }
    .nav-link {
        font-family: var(--font-body);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-white);
        opacity: 0.8;
    }
    .nav-link:hover {
        opacity: 1;
        color: var(--color-gold);
    }
    .lang-switcher {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        color: var(--color-white);
        font-family: var(--font-body);
        font-size: 0.85rem;
        letter-spacing: 0.1em;
    }
    .lang-switcher a {
        color: var(--color-gray);
        text-decoration: none;
        transition: color 0.3s;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
        color: var(--color-gold);
    }
    .lang-switcher span {
        color: var(--color-gray);
        opacity: 0.5;
    }
    .site-footer {
        padding: var(--spacing-lg) 0;
        text-align: center;
        border-top: 1px solid rgba(212, 175, 55, 0.1); /* Subtle gold border */
    }
    .footer-text {
        font-size: 0.8rem;
        color: var(--color-gray);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    /* Menu Toggle Button */
    .menu-toggle {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 30px;
        height: 20px;
        background: transparent;
        border: none;
        cursor: pointer;
        z-index: 110;
        padding: 0;
    }
    .hamburger-line {
        display: block;
        width: 100%;
        height: 2px;
        background-color: var(--color-white);
        transition: transform 0.3s ease, opacity 0.3s ease, background-color 0.3s ease;
    }
    .menu-toggle.open .hamburger-line:nth-child(1) {
        transform: translateY(9px) rotate(45deg);
        background-color: var(--color-gold);
    }
    .menu-toggle.open .hamburger-line:nth-child(2) {
        opacity: 0;
    }
    .menu-toggle.open .hamburger-line:nth-child(3) {
        transform: translateY(-9px) rotate(-45deg);
        background-color: var(--color-gold);
    }

    /* Mobile Navigation Overlay */
    .mobile-menu-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: rgba(5, 5, 5, 0.95);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        z-index: 95;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(-20px);
        transition: opacity 0.4s ease, transform 0.4s ease, visibility 0.4s;
    }
    .mobile-menu-overlay.open {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0);
    }
    .mobile-nav {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2.5rem;
        text-align: center;
    }
    .mobile-nav-link {
        font-family: var(--font-display);
        font-size: 2rem;
        color: var(--color-white);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: color 0.3s;
    }
    .mobile-nav-link:hover {
        color: var(--color-gold);
    }
    .mobile-lang-switcher {
        display: flex;
        gap: 1rem;
        align-items: center;
        color: var(--color-white);
        font-family: var(--font-body);
        font-size: 1.2rem;
        margin-top: 1rem;
        letter-spacing: 0.1em;
    }
    .mobile-lang-switcher a {
        color: var(--color-gray);
        text-decoration: none;
        transition: color 0.3s;
    }
    .mobile-lang-switcher a.active, .mobile-lang-switcher a:hover {
        color: var(--color-gold);
    }
    .mobile-lang-switcher span {
        color: var(--color-gray);
        opacity: 0.5;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
        .site-header {
            padding: var(--spacing-sm) 0;
        }
        .site-logo {
            height: 70px;
        }
        .main-nav {
            display: none;
        }
        .lang-switcher {
            display: none;
        }
        .menu-toggle {
            display: flex;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const body = document.body;
        const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

        if (menuToggle && mobileMenu) {
            const toggleMenu = () => {
                const isOpen = mobileMenu.classList.toggle('open');
                menuToggle.classList.toggle('open');
                menuToggle.setAttribute('aria-expanded', String(isOpen));
                body.classList.toggle('no-scroll', isOpen);
            };

            menuToggle.addEventListener('click', toggleMenu);

            // Close menu when a link is clicked
            mobileNavLinks.forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.remove('open');
                    menuToggle.classList.remove('open');
                    menuToggle.setAttribute('aria-expanded', 'false');
                    body.classList.remove('no-scroll');
                });
            });
        }
    });
</script>
