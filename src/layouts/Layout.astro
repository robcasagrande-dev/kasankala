---
import '../styles/global.css';

export interface Props {
	title: string;
}

const { title } = Astro.props;
const lang = Astro.currentLocale || 'es';
const isEn = lang === 'en';
---

<!DOCTYPE html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        <meta name="description" content="Kásankala: El encuentro entre la selva y el lujo en el corazón del Tayrona." />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
        <header class="site-header">
            <div class="container header-container">
                <a href="/" class="logo-link">
                    <img src="/logo-color.svg" alt="Kásankala" class="site-logo" />
                </a>
                <nav class="main-nav">
                    <!-- Minimal navigation, can be expanded later -->
                    <a href={isEn ? '/en/#concept' : '/#concept'} class="nav-link">{isEn ? 'Essence' : 'Esencia'}</a>
                    <a href={isEn ? '/en/#gallery' : '/#gallery'} class="nav-link">{isEn ? 'Atmosphere' : 'Atmósfera'}</a>
                    <a href={isEn ? '/en/menu' : '/menu'} class="nav-link">{isEn ? 'Menu' : 'Menú'}</a>
                </nav>
                <div class="lang-switcher">
                    <a href="/" class={!isEn ? 'active' : ''}>ES</a>
                    <span>|</span>
                    <a href="/en/" class={isEn ? 'active' : ''}>EN</a>
                </div>
            </div>
        </header>

		<slot />

        <footer class="site-footer">
            <div class="container footer-container">
                <p class="footer-text">&copy; {new Date().getFullYear()} Kásankala. {isEn ? 'All rights reserved.' : 'Todos los derechos reservados.'}</p>
            </div>
        </footer>
	</body>
</html>

<style>
    .site-header {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        padding: var(--spacing-md) 0;
        z-index: 100;
        background: linear-gradient(to bottom, rgba(5,5,5,0.8) 0%, rgba(5,5,5,0) 100%);
    }
    .header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    .site-logo {
        height: 120px;
        width: auto;
    }
    .main-nav {
        display: flex;
        gap: var(--spacing-md);
    }
    .nav-link {
        font-family: var(--font-body);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-white);
        opacity: 0.8;
    }
    .nav-link:hover {
        opacity: 1;
        color: var(--color-gold);
    }
    .lang-switcher {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        color: var(--color-white);
        font-family: var(--font-body);
        font-size: 0.85rem;
        letter-spacing: 0.1em;
    }
    .lang-switcher a {
        color: var(--color-gray);
        text-decoration: none;
        transition: color 0.3s;
    }
    .lang-switcher a.active, .lang-switcher a:hover {
        color: var(--color-gold);
    }
    .lang-switcher span {
        color: var(--color-gray);
        opacity: 0.5;
    }
    .site-footer {
        padding: var(--spacing-lg) 0;
        text-align: center;
        border-top: 1px solid rgba(212, 175, 55, 0.1); /* Subtle gold border */
    }
    .footer-text {
        font-size: 0.8rem;
        color: var(--color-gray);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }
</style>
